{
  "buildCommand": "npm run build:shared && npm run build:dashboard",
  "outputDirectory": "packages/dashboard/dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/api/v1/health", "destination": "/api/v1/health" },
    { "source": "/api/v1/events/batch", "destination": "/api/v1/events/batch" },
    { "source": "/api/v1/d/:path*", "destination": "/api/v1/d/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
